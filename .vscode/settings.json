{
    "explorer.compactFolders": true,
    "explorer.excludeGitIgnore": true,
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.expand": false,
    "explorer.fileNesting.patterns": {
        "Cargo.toml": "Cargo.lock, .cargo",
        "Makefile": "scripts, tools",
        "README.md": "ROADMAP.md, CONTRIBUTING.md, SECURITY.md, LICENSE, extension.schema.json",
        "package.json": "package-lock.json, tsconfig*.json, vite.config.*, index.html"
    },
    "typescript.tsdk": "apps/desktop/node_modules/typescript/lib",
    "typescript.enablePromptUseWorkspaceTsdk": true,
    "typescript.tsserver.maxTsServerMemory": 4096,
    "typescript.preferences.importModuleSpecifier": "non-relative",
    "rust-analyzer.linkedProjects": [
        "Cargo.toml"
    ],
    "rust-analyzer.cargo.targetDir": ".irodori-local/rust-analyzer-target",
    "rust-analyzer.cargo.features": [],
    "rust-analyzer.check.command": "clippy",
    "rust-analyzer.check.extraArgs": [
        "--workspace",
        "--all-targets"
    ],
    "rust-analyzer.files.excludeDirs": [
        ".cache",
        ".irodori-dev",
        ".irodori-local",
        "apps/desktop/dist",
        "apps/desktop/node_modules",
        "node_modules",
        "ref"
    ],
    "editor.formatOnSave": false,
    "[rust]": {
        "editor.defaultFormatter": "rust-lang.rust-analyzer"
    },
    "[typescript]": {
        "editor.defaultFormatter": "oxc.oxc-vscode"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "oxc.oxc-vscode"
    },
    "[json]": {
        "editor.defaultFormatter": "oxc.oxc-vscode"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "oxc.oxc-vscode"
    },
    "files.exclude": {
        "**/.agents": true,
        "**/.cache": true,
        "**/.cargo": true,
        "**/.claude": true,
        "**/.codex": true,
        "**/.config": true,
        "**/.github": true,
        "**/.irodori-local": true,
        "**/.irodori-local/**": true,
        "**/.irodori-dev": true,
        "**/.irodori-dev/**": true,
        "**/.local": true,
        "**/ref/**": true,
        "**/{.irodori-local,.irodori-dev,ref}/**/{codeql-pack.yml,qlpack.yml,codeql-pack.lock.yml,qlpack.lock.yml}": true,
        "**/dist": true,
        "**/node_modules": true,
        "**/target": true,
        "docs/site/try/assets": true,
        "knowledge/*.sqlite*": true,
        "ref": true
    },
    "search.exclude": {
        "**/.agents": true,
        "**/.cache": true,
        "**/.claude": true,
        "**/.codex": true,
        "**/.irodori-local": true,
        "**/.irodori-local/**": true,
        "**/.irodori-dev": true,
        "**/.irodori-dev/**": true,
        "**/.local": true,
        "**/ref/**": true,
        "**/{.irodori-local,.irodori-dev,ref}/**/{codeql-pack.yml,qlpack.yml,codeql-pack.lock.yml,qlpack.lock.yml}": true,
        "**/dist": true,
        "**/node_modules": true,
        "**/target": true,
        "docs/site/try/assets": true,
        "knowledge/*.sqlite*": true,
        "ref": true
    },
    "files.watcherExclude": {
        "**/.cache/**": true,
        "**/.irodori-local/**": true,
        "**/.irodori-dev/**": true,
        "**/.local/**": true,
        "**/ref/**": true,
        "**/{.irodori-local,.irodori-dev,ref}/**/{codeql-pack.yml,qlpack.yml,codeql-pack.lock.yml,qlpack.lock.yml}": true,
        "**/dist/**": true,
        "**/node_modules/**": true,
        "**/target/**": true,
        "docs/site/try/assets/**": true,
        "ref/**": true
    },
    "workbench.colorCustomizations": {
        "activityBar.activeBackground": "#80fbc4",
        "activityBar.background": "#80fbc4",
        "activityBar.foreground": "#15202b",
        "activityBar.inactiveForeground": "#15202b99",
        "activityBarBadge.background": "#c683fb",
        "activityBarBadge.foreground": "#15202b",
        "commandCenter.border": "#15202b99",
        "sash.hoverBorder": "#80fbc4",
        "statusBar.background": "#4ff9ad",
        "statusBar.foreground": "#15202b",
        "statusBarItem.hoverBackground": "#1ef796",
        "statusBarItem.remoteBackground": "#4ff9ad",
        "statusBarItem.remoteForeground": "#15202b",
        "titleBar.activeBackground": "#4ff9ad",
        "titleBar.activeForeground": "#15202b",
        "titleBar.inactiveBackground": "#4ff9ad99",
        "titleBar.inactiveForeground": "#15202b99"
    }
}
