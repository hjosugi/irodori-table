{
  "$schema": "../../../extension.schema.json",
  "manifestVersion": 1,
  "id": "example.markdown-result-export",
  "name": "Markdown Result Export",
  "version": "0.1.0",
  "description": "Copies the active result grid as a Markdown table.",
  "license": "MIT OR 0BSD",
  "apiVersion": "0.1",
  "runtime": "typescript",
  "entry": "dist/main.js",
  "permissions": ["commands", "keybindings", "queryResults:read", "resultRenderers"],
  "contributes": {
    "commands": [
      {
        "id": "markdownResultExport.copy",
        "title": "Copy Result as Markdown",
        "category": "Result Grid",
        "enablement": "resultGridFocus"
      }
    ],
    "keybindings": [
      {
        "command": "markdownResultExport.copy",
        "key": "cmd+shift+m",
        "windows": "ctrl+shift+m",
        "linux": "ctrl+shift+m",
        "when": "resultGridFocus"
      }
    ],
    "resultGridActions": [
      {
        "id": "markdownResultExport.action",
        "title": "Copy as Markdown",
        "command": "markdownResultExport.copy",
        "when": "resultGridFocus"
      }
    ]
  },
  "dev": {
    "watch": ["src", "fixtures/fake-db.json"],
    "logFile": ".irodori-dev/extension.log"
  }
}
