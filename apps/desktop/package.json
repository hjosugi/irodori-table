{
  "name": "irodori-table-desktop",
  "version": "0.7.6",
  "private": true,
  "license": "MIT OR 0BSD",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "vite",
    "icons": "node tools/generate-icons.mjs",
    "typegen": "node tools/typegen.mjs",
    "typegen:desktop": "node tools/typegen.mjs --only desktop",
    "typegen:check": "node tools/typegen.mjs --check",
    "format": "oxfmt --write \"src/**/*.{js,jsx,ts,tsx,json,jsonc}\" \"tools/**/*.{js,mjs,cjs,ts,tsx,json,jsonc}\" \"e2e/**/*.{js,jsx,ts,tsx}\" \"*.config.ts\"",
    "format:check": "oxfmt --check \"src/**/*.{js,jsx,ts,tsx,json,jsonc}\" \"tools/**/*.{js,mjs,cjs,ts,tsx,json,jsonc}\" \"e2e/**/*.{js,jsx,ts,tsx}\" \"*.config.ts\"",
    "lint": "oxlint src tools e2e",
    "build": "tsgo && vite build",
    "build:verified": "node tools/typegen.mjs --check && tsgo && vite build",
    "build:with-typegen": "node tools/typegen.mjs && tsgo && vite build",
    "verify:release": "node tools/typegen.mjs --check && tsgo --noEmit",
    "typecheck": "tsgo --noEmit",
    "typecheck:native": "tsgo --noEmit",
    "release:appimage": "node tools/build-linux-release.mjs appimage",
    "release:linux": "node tools/build-linux-release.mjs linux",
    "release:prepare-macos-signing": "node tools/prepare-macos-signing.mjs",
    "release:prepare-updater": "node tools/prepare-updater-config.mjs",
    "release:prepare-windows-signing": "node tools/prepare-windows-signing.mjs",
    "release:verify-linux": "node tools/verify-linux-release.mjs",
    "release:patch": "node tools/release.mjs patch",
    "release:minor": "node tools/release.mjs minor",
    "release:major": "node tools/release.mjs major",
    "test": "vitest run",
    "test:all": "node tools/test-rust-ts.mjs",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:watch": "vitest",
    "test:rust": "node tools/test-rust-ts.mjs --rust-only",
    "test:rust-ts": "node tools/test-rust-ts.mjs",
    "test:e2e": "node tools/playwright-test.mjs",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@replit/codemirror-indentation-markers": "^6.5.3",
    "@replit/codemirror-vim": "^6.3.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xstate/react": "^6.1.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "codemirror": "^6.0.2",
    "dockview-react": "^7.0.2",
    "lucide-react": "^1.22.0",
    "mermaid": "^11.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sql-formatter": "^15.8.2",
    "write-excel-file": "^4.1.1",
    "xstate": "^5.32.2",
    "yaml": "^2.9.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@playwright/test": "^1.61.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tauri-apps/cli": "^2",
    "@types/babel__core": "^7.20.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260702.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "^4.1.9",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^29.1.1",
    "oxfmt": "0.56.0",
    "oxlint": "^1.72.0",
    "typescript": "~6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
