{
  "name": "irodori-table-desktop",
  "private": true,
  "version": "0.3.4",
  "license": "MIT OR 0BSD",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "icons": "node tools/generate-icons.mjs",
    "typegen": "node tools/typegen.mjs",
    "typegen:desktop": "node tools/typegen.mjs --only desktop",
    "typegen:extension": "node tools/typegen.mjs --only extension",
    "typegen:check": "node tools/typegen.mjs --check",
    "build": "tsc && vite build",
    "build:verified": "node tools/typegen.mjs --check && tsc && vite build",
    "build:with-typegen": "node tools/typegen.mjs && tsc && vite build",
    "release:appimage": "node tools/build-linux-release.mjs appimage",
    "release:linux": "node tools/build-linux-release.mjs linux",
    "release:verify-linux": "node tools/verify-linux-release.mjs",
    "release:patch": "node tools/release.mjs patch",
    "release:minor": "node tools/release.mjs minor",
    "release:major": "node tools/release.mjs major",
    "test": "vitest run",
    "test:all": "node tools/test-rust-ts.mjs",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:watch": "vitest",
    "test:rust": "node tools/test-rust-ts.mjs --rust-only",
    "test:rust-ts": "node tools/test-rust-ts.mjs",
    "test:e2e": "node tools/playwright-test.mjs",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "@replit/codemirror-vim": "^6.3.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "codemirror": "^6.0.2",
    "lucide-react": "^1.21.0",
    "mermaid": "^11.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sql-formatter": "^15.8.2",
    "yaml": "^2.9.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@playwright/test": "^1.61.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tauri-apps/cli": "^2",
    "@types/babel__core": "^7.20.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "^4.1.9",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
