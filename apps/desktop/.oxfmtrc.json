{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "endOfLine": "lf",
  "insertFinalNewline": true,
  "printWidth": 80,
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "all",
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "src/generated/**",
    "test-results/**",
    ".vitest-attachments/**",
    "src/tests/browser/__screenshots__/**"
  ]
}
