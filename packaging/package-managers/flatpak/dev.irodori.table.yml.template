app-id: dev.irodori.table
runtime: org.gnome.Platform
runtime-version: "__RUNTIME_VERSION__"
sdk: org.gnome.Sdk
command: irodori-table
finish-args:
  - --share=network
  - --socket=wayland
  - --socket=fallback-x11
  - --device=dri
  - --filesystem=xdg-documents
modules:
  - name: irodori-table
    buildsystem: simple
    build-commands:
      - install -Dm755 __BINARY_OR_WRAPPER__ /app/bin/irodori-table
      - install -Dm644 packaging/appstream/dev.irodori.table.metainfo.xml /app/share/metainfo/dev.irodori.table.metainfo.xml
      - install -Dm644 packaging/linux/dev.irodori.table.desktop /app/share/applications/dev.irodori.table.desktop
      - install -Dm644 __ICON_FILE__ /app/share/icons/hicolor/512x512/apps/dev.irodori.table.png
    sources:
      - type: archive
        url: https://github.com/hjosugi/irodori-table/releases/download/v__VERSION__/__FLATPAK_SOURCE_ASSET__
        sha256: __SHA256_FLATPAK_SOURCE__
