name: irodori-table
base: core24
version: "__VERSION__"
summary: Open-source SQL workbench for multiple database engines.
description: |
  Irodori Table is a local-first desktop database workbench for SQL editing,
  schema inspection, result browsing, and database workflows.

  It is a development preview. Review SQL before running destructive commands.

grade: stable
confinement: strict
license: "MIT OR 0BSD"

apps:
  irodori-table:
    command: __COMMAND__
    desktop: __DESKTOP_FILE__
    plugs:
      - network
      - network-bind
      - home
      - wayland
      - x11
      - desktop
      - desktop-legacy
      - opengl

parts:
  irodori-table:
    plugin: dump
    source: https://github.com/hjosugi/irodori-table/releases/download/v__VERSION__/__SNAP_SOURCE_ASSET__
    source-checksum: sha256/__SHA256_SNAP_SOURCE__
