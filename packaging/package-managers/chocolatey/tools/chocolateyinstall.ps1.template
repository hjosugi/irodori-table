$ErrorActionPreference = 'Stop'

$packageName  = 'irodori-table'
$softwareName = 'Irodori Table*'
$url64        = 'https://github.com/hjosugi/irodori-table/releases/download/v__VERSION__/__WINDOWS_INSTALLER_ASSET__'

# Remove any previously installed Irodori Table before installing the new
# build. Chocolatey re-runs this script on upgrade, and some installer types
# (notably NSIS/EXE) leave the prior version in place, so uninstall it first to
# avoid two copies sitting side by side.
[array]$installed = Get-UninstallRegistryKey -SoftwareName $softwareName
foreach ($entry in $installed) {
  $uninstallCommand = $entry.QuietUninstallString
  if (-not $uninstallCommand) {
    $uninstallCommand = $entry.UninstallString
  }
  if (-not $uninstallCommand) {
    continue
  }

  Write-Host "Uninstalling previous version: $($entry.DisplayName)"
  $removalExitCodes = @(0, 3010, 1605, 1614, 1641)

  if ($uninstallCommand -match '(?i)msiexec') {
    # Windows Installer: drive the registered product code unattended.
    # Uninstall-ChocolateyPackage prepends `/x` and runs msiexec for the `msi`
    # file type, so the product code and flags are all that is needed here.
    $productCode = [regex]::Match($uninstallCommand, '\{[0-9A-Fa-f-]+\}').Value
    Uninstall-ChocolateyPackage `
      -PackageName $packageName `
      -FileType 'msi' `
      -SilentArgs "$productCode /qn /norestart" `
      -ValidExitCodes $removalExitCodes
  }
  else {
    # NSIS/EXE: split the registered path from any trailing args and force a
    # silent uninstall with `/S`.
    if ($uninstallCommand.StartsWith('"')) {
      $closingQuote = $uninstallCommand.IndexOf('"', 1)
      $file         = $uninstallCommand.Substring(1, $closingQuote - 1)
      $existingArgs = $uninstallCommand.Substring($closingQuote + 1).Trim()
    }
    else {
      $parts        = $uninstallCommand -split ' ', 2
      $file         = $parts[0]
      $existingArgs = if ($parts.Count -gt 1) { $parts[1].Trim() } else { '' }
    }

    Uninstall-ChocolateyPackage `
      -PackageName $packageName `
      -FileType 'exe' `
      -SilentArgs ("/S $existingArgs").Trim() `
      -File $file `
      -ValidExitCodes $removalExitCodes
  }
}

$packageArgs = @{
  packageName    = $packageName
  fileType       = '__MSI_OR_EXE__'
  url64bit       = $url64
  softwareName   = $softwareName
  checksum64     = '__SHA256_WINDOWS_INSTALLER__'
  checksumType64 = 'sha256'
  silentArgs     = '__SILENT_INSTALL_ARGS__'
  validExitCodes = @(0, 3010, 1641)
}

Install-ChocolateyPackage @packageArgs
