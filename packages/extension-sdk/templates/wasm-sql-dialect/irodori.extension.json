{
  "$schema": "../../../../extension.schema.json",
  "manifestVersion": 1,
  "id": "example.wasm-sql-dialect",
  "name": "Wasm SQL Dialect Skeleton",
  "version": "0.1.0",
  "description": "Skeleton for a high-performance Wasm SQL dialect/parser extension.",
  "license": "MIT OR 0BSD",
  "apiVersion": "0.1",
  "runtime": "wasm",
  "entry": "pkg/wasm_sql_dialect.js",
  "permissions": ["sqlDialects", "wasm"],
  "contributes": {
    "sqlDialects": [
      {
        "id": "wasmSqlDialect.fastSql",
        "name": "Fast SQL",
        "path": "dialects/fast-sql.json",
        "fileExtensions": [".fsql"]
      }
    ]
  },
  "capabilities": {
    "wasmModules": [
      {
        "id": "wasmSqlDialect.parser",
        "path": "pkg/wasm_sql_dialect_bg.wasm",
        "abi": "irodori-sql-dialect-v0",
        "exports": ["parse", "complete", "format"]
      }
    ]
  }
}
