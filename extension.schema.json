{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://irodori.dev/schemas/irodori.extension.schema.json",
  "title": "Irodori Table Extension Manifest",
  "description": "Schema for irodori.extension.json.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifestVersion",
    "id",
    "name",
    "version",
    "license",
    "apiVersion",
    "runtime",
    "entry",
    "permissions"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "manifestVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]*\\.[a-z0-9][a-z0-9.-]*$",
      "examples": ["example.quick-export"]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "publisher": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "license": {
      "type": "string",
      "minLength": 1,
      "default": "MIT OR 0BSD"
    },
    "repository": {
      "type": "string"
    },
    "apiVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$",
      "default": "0.1"
    },
    "runtime": {
      "$ref": "#/$defs/runtime"
    },
    "entry": {
      "type": "string",
      "minLength": 1
    },
    "permissions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/permission"
      },
      "uniqueItems": true
    },
    "contributes": {
      "$ref": "#/$defs/contributes"
    },
    "capabilities": {
      "$ref": "#/$defs/capabilities"
    },
    "dev": {
      "$ref": "#/$defs/devConfig"
    }
  },
  "$defs": {
    "runtime": {
      "type": "string",
      "enum": ["typescript", "javascript", "wasm", "native"]
    },
    "permission": {
      "type": "string",
      "enum": [
        "commands",
        "keybindings",
        "workspace:read",
        "connections:read",
        "connections:write",
        "connectors",
        "queries:run",
        "queryResults:read",
        "queryResults:write",
        "metadata:read",
        "files:read",
        "files:write",
        "themes",
        "sqlDialects",
        "statusBar",
        "resultRenderers",
        "logs",
        "dev:fixtures",
        "native",
        "wasm"
      ]
    },
    "contributes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "commands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/command"
          }
        },
        "keybindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/keybinding"
          }
        },
        "resultGridActions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/resultGridAction"
          }
        },
        "resultGridRenderers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/resultGridRenderer"
          }
        },
        "statusBarItems": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/statusBarItem"
          }
        },
        "themes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/themeContribution"
          }
        },
        "sqlDialects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sqlDialectContribution"
          }
        },
        "connectors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/connectorContribution"
          }
        }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title"],
      "properties": {
        "id": {
          "$ref": "#/$defs/contributionId"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string"
        },
        "enablement": {
          "type": "string"
        }
      }
    },
    "keybinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "key"],
      "properties": {
        "command": {
          "$ref": "#/$defs/contributionId"
        },
        "key": {
          "type": "string",
          "minLength": 1
        },
        "mac": {
          "type": "string"
        },
        "windows": {
          "type": "string"
        },
        "linux": {
          "type": "string"
        },
        "when": {
          "type": "string"
        }
      }
    },
    "resultGridAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "command"],
      "properties": {
        "id": {
          "$ref": "#/$defs/contributionId"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "$ref": "#/$defs/contributionId"
        },
        "when": {
          "type": "string"
        }
      }
    },
    "resultGridRenderer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "path"],
      "properties": {
        "id": {
          "$ref": "#/$defs/contributionId"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "mediaTypes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "statusBarItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": {
          "$ref": "#/$defs/contributionId"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "alignment": {
          "type": "string",
          "enum": ["left", "right"]
        },
        "priority": {
          "type": "integer"
        },
        "command": {
          "$ref": "#/$defs/contributionId"
        },
        "tooltip": {
          "type": "string"
        },
        "when": {
          "type": "string"
        }
      }
    },
    "themeContribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "path"],
      "properties": {
        "id": {
          "$ref": "#/$defs/contributionId"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "kind": {
          "type": "string",
          "enum": ["light", "dark", "highContrast"]
        }
      }
    },
    "sqlDialectContribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "path"],
      "properties": {
        "id": {
          "$ref": "#/$defs/contributionId"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "fileExtensions": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^\\.[A-Za-z0-9_-]+$"
          },
          "uniqueItems": true
        }
      }
    },
    "connectorContribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "engine", "label"],
      "properties": {
        "id": {
          "$ref": "#/$defs/contributionId"
        },
        "engine": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "defaultPort": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535
        },
        "wire": {
          "type": "string",
          "minLength": 1
        },
        "module": {
          "$ref": "#/$defs/contributionId"
        },
        "dialect": {
          "$ref": "#/$defs/contributionId"
        },
        "features": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "sql",
              "metadata",
              "transactions",
              "streaming",
              "preparedQueries",
              "explain",
              "resultEditing"
            ]
          },
          "uniqueItems": true
        },
        "connection": {
          "$ref": "#/$defs/connectorConnectionModel"
        }
      }
    },
    "connectorConnectionModel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "inferEnvironmentFrom",
        "compatibility",
        "defaults",
        "endpoint",
        "profileFields",
        "authMethods",
        "secretPurposes",
        "tls",
        "transports",
        "optionNamespaces",
        "customDriverOptions"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "inferEnvironmentFrom": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "compatibility": {
          "type": "object",
          "additionalProperties": false,
          "required": ["addsRequiredProfileFields", "acceptsExistingProfiles"],
          "properties": {
            "addsRequiredProfileFields": {
              "type": "boolean"
            },
            "acceptsExistingProfiles": {
              "type": "boolean"
            }
          }
        },
        "defaults": {
          "type": "object",
          "additionalProperties": false,
          "required": ["engine", "wire", "port", "readOnly"],
          "properties": {
            "engine": {
              "type": "string",
              "minLength": 1
            },
            "wire": {
              "type": "string",
              "minLength": 1
            },
            "port": {
              "type": "integer",
              "minimum": 0,
              "maximum": 65535
            },
            "readOnly": {
              "type": "boolean"
            }
          }
        },
        "endpoint": {
          "$ref": "#/$defs/connectorEndpointModel"
        },
        "profileFields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/connectorConnectionField"
          }
        },
        "authMethods": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/connectorAuthMethod"
          }
        },
        "secretPurposes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/connectorSecretPurpose"
          },
          "uniqueItems": true
        },
        "tls": {
          "$ref": "#/$defs/connectorTlsModel"
        },
        "transports": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/connectorTransportMode"
          },
          "uniqueItems": true
        },
        "optionNamespaces": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "customDriverOptions": {
          "type": "boolean"
        }
      }
    },
    "connectorEndpointModel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["modes", "defaultPort", "fields"],
      "properties": {
        "modes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/connectorEndpointMode"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "defaultPort": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/connectorConnectionField"
          }
        }
      }
    },
    "connectorAuthMethod": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "kind", "secretPurposes", "fields"],
      "properties": {
        "id": {
          "$ref": "#/$defs/contributionId"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "none",
            "connectionString",
            "userPassword",
            "basic",
            "token",
            "apiKey",
            "oauth2",
            "serviceAccount",
            "privateKey",
            "certificate",
            "kerberos",
            "ldap",
            "saml",
            "iam",
            "azureAd",
            "managedIdentity",
            "browserSso",
            "custom"
          ]
        },
        "secretPurposes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/connectorSecretPurpose"
          },
          "uniqueItems": true
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/connectorConnectionField"
          }
        }
      }
    },
    "connectorConnectionField": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "type"],
      "properties": {
        "id": {
          "$ref": "#/$defs/contributionId"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "string",
            "number",
            "boolean",
            "secret",
            "path",
            "json",
            "pem",
            "uri",
            "select",
            "stringList",
            "map"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "profileField": {
          "type": "string",
          "minLength": 1
        },
        "option": {
          "type": "string",
          "minLength": 1
        },
        "secretPurpose": {
          "$ref": "#/$defs/connectorSecretPurpose"
        },
        "default": {},
        "description": {
          "type": "string"
        }
      }
    },
    "connectorTlsModel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["supported", "requiredByDefault", "modes", "fields"],
      "properties": {
        "supported": {
          "type": "boolean"
        },
        "requiredByDefault": {
          "type": "boolean"
        },
        "modes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["disable", "prefer", "require", "verifyCa", "verifyFull", "clientCertificate"]
          },
          "uniqueItems": true
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/connectorConnectionField"
          }
        }
      }
    },
    "connectorSecretPurpose": {
      "type": "string",
      "enum": [
        "password",
        "token",
        "privateKey",
        "privateKeyPassphrase",
        "sshPassword",
        "proxyPassword"
      ]
    },
    "connectorEndpointMode": {
      "type": "string",
      "enum": [
        "hostPort",
        "connectionString",
        "localFile",
        "inMemory",
        "motherduckService",
        "cloudResource",
        "customEndpoint",
        "catalog",
        "objectStorage",
        "jdbc"
      ]
    },
    "connectorTransportMode": {
      "type": "string",
      "enum": [
        "direct",
        "localFile",
        "sshTunnel",
        "socks5Proxy",
        "httpConnectProxy",
        "proxyChain",
        "customEndpoint"
      ]
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "wasmModules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/wasmModule"
          }
        },
        "nativeModules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nativeModule"
          }
        }
      }
    },
    "wasmModule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "abi"],
      "properties": {
        "id": {
          "$ref": "#/$defs/contributionId"
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "abi": {
          "type": "string",
          "minLength": 1
        },
        "exports": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "nativeModule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "platforms"],
      "properties": {
        "id": {
          "$ref": "#/$defs/contributionId"
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "platforms": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "windowsX64",
              "windowsArm64",
              "macosX64",
              "macosArm64",
              "linuxX64",
              "linuxArm64"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        }
      }
    },
    "devConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "watch": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relativePath"
          },
          "uniqueItems": true
        },
        "fixtures": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fakeDatabaseFixture"
          }
        },
        "logFile": {
          "$ref": "#/$defs/relativePath"
        }
      }
    },
    "fakeDatabaseFixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "engine"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "engine": {
          "type": "string",
          "minLength": 1
        },
        "schemas": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fakeSchemaFixture"
          }
        }
      }
    },
    "fakeSchemaFixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "tables": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fakeTableFixture"
          }
        }
      }
    },
    "fakeTableFixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "columns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fakeColumnFixture"
          }
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      }
    },
    "fakeColumnFixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "dataType"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "dataType": {
          "type": "string",
          "minLength": 1
        },
        "nullable": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "contributionId": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "^(?:/|[A-Za-z]:|.*\\.\\.(?:/|\\\\))"
      }
    }
  }
}
